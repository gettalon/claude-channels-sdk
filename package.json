{
  "name": "@gettalon/channels-sdk",
  "version": "1.0.4",
  "description": "SDK for building Claude Code channels with bidirectional chat, permission relay, and all 23 hook events",
  "bin": {
    "claude-hook": "./dist/hook-script.js",
    "claude-channels": "./dist/setup.js",
    "channels": "./dist/server.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./channels": {
      "types": "./dist/channels/index.d.ts",
      "import": "./dist/channels/index.js"
    },
    "./telegram": {
      "types": "./dist/channels/telegram.d.ts",
      "import": "./dist/channels/telegram.js"
    },
    "./discord": {
      "types": "./dist/channels/discord.d.ts",
      "import": "./dist/channels/discord.js"
    },
    "./slack": {
      "types": "./dist/channels/slack.d.ts",
      "import": "./dist/channels/slack.js"
    },
    "./whatsapp": {
      "types": "./dist/channels/whatsapp.d.ts",
      "import": "./dist/channels/whatsapp.js"
    },
    "./matrix": {
      "types": "./dist/channels/matrix.d.ts",
      "import": "./dist/channels/matrix.js"
    },
    "./signal": {
      "types": "./dist/channels/signal.d.ts",
      "import": "./dist/channels/signal.js"
    },
    "./irc": {
      "types": "./dist/channels/irc.d.ts",
      "import": "./dist/channels/irc.js"
    },
    "./line": {
      "types": "./dist/channels/line.d.ts",
      "import": "./dist/channels/line.js"
    },
    "./feishu": {
      "types": "./dist/channels/feishu.d.ts",
      "import": "./dist/channels/feishu.js"
    },
    "./msteams": {
      "types": "./dist/channels/msteams.d.ts",
      "import": "./dist/channels/msteams.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "setup": "node dist/setup.js",
    "postinstall": "node dist/postinstall.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6",
    "discord.js": "^14.0.0",
    "@slack/bolt": "^3.0.0",
    "@whiskeysockets/baileys": "^6.0.0",
    "matrix-js-sdk": "^30.0.0",
    "irc-framework": "^4.0.0",
    "@line/bot-sdk": "^9.0.0",
    "@larksuiteoapi/node-sdk": "^1.0.0",
    "botbuilder": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gettalon/claude-channels-sdk"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "channels",
    "hooks",
    "talon",
    "sdk"
  ],
  "files": [
    "dist",
    "README.md"
  ]
}
